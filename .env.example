# Machine Learning Settings
ML_URL=http://immich-machine-learning:3003

# Database
DB_PASSWORD=postgres
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# Upload location (local storage for new uploads)
UPLOAD_LOCATION=/path/to/immich/upload

# External library location (NAS or secondary storage)
PHOTO_LIBRARY_LOCATION=/path/to/your/external/library

# Optional: Machine Learning Settings
MACHINE_LEARNING_ENABLED=true

# Optional: Disable telemetry
# IMMICH_TELEMETRY_DISABLED=true

# Redis
REDIS_HOSTNAME=redis
